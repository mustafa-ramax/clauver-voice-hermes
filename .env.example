LIVEKIT_URL=<your LiveKit server URL>
LIVEKIT_API_KEY=<your API Key>
LIVEKIT_API_SECRET=<your API Secret>
SIP_OUTBOUND_TRUNK_ID=<your SIP outbound trunk ID>

# Boss name (used as default for outbound calls; can be overridden per-call)
BOSS_NAME=Max

# AGENT_MODE=cloud
CLAUVER_AGENT_NAME=clauver-general

# CLAUVER_LLM_OVERRIDE=openai
# OPENAI_API_KEY=<your OpenAI API Key>

# --- PREMIUM STT OPTION ---
# Deepgram gives streaming, low-latency STT (~200ms vs ~1.2s with local Whisper).
# CLAUVER_STT_OVERRIDE=deepgram
# DEEPGRAM_API_KEY=<your Deepgram API Key>

# --- PREMIUM TTS OPTION ---
# CARTESIA_API_KEY=<your Cartesia API Key>
# CLAUVER_TTS_OVERRIDE=cartesia

# --- DISABLE LIVEKIT TELEMETRY ---
# Prevents post-call ReadTimeout errors trying to upload metrics to LiveKit cloud.
# Set to "true" to disable all OpenTelemetry exports (no effect on call quality).
OTEL_SDK_DISABLED=true

# Note: if you are using EdgeTTS Hermes agent default TTS, 
# Remember to install ffmpeg on your system: brew install ffmpeg