# ═══════════════════════════════════════════════════════════════════
# CLAUVER VOICE — CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
#
# LLM, TTS, and STT are AUTO-DETECTED from your Hermes config
# (~/.hermes/config.yaml). You only need LiveKit keys below.
#
# Override any provider if you want Clauver to use something
# different from your Hermes setup.
# ═══════════════════════════════════════════════════════════════════

# --- REQUIRED: LiveKit + SIP (get these from cloud.livekit.io) ---
LIVEKIT_URL=<your LiveKit server URL>
LIVEKIT_API_KEY=<your API Key>
LIVEKIT_API_SECRET=<your API Secret>
SIP_OUTBOUND_TRUNK_ID=<your SIP outbound trunk ID>

# --- IDENTITY ---
BOSS_NAME=Boss
CLAUVER_AGENT_NAME=clauver-general

# --- OPTIONAL: Override LLM ---
# Bypass Hermes LLM. Options: openai
# CLAUVER_LLM_OVERRIDE=openai
# OPENAI_API_KEY=<key>

# --- OPTIONAL: Override TTS ---
# Bypass Hermes TTS. Options: cartesia, deepgram, elevenlabs, openai, edge, xai, mistral
# CLAUVER_TTS_OVERRIDE=cartesia
# CLAUVER_TTS_API_KEY=<key for whichever provider you chose above>

# --- OPTIONAL: Override STT ---
# Bypass Hermes STT. Options: deepgram, openai, elevenlabs, mistral
# CLAUVER_STT_OVERRIDE=deepgram
# CLAUVER_STT_API_KEY=<key for whichever provider you chose above>

# --- PERFORMANCE ---
# Prevents post-call ReadTimeout errors trying to upload metrics to LiveKit cloud.
# Set to "true" to disable all OpenTelemetry exports (no effect on call quality).
OTEL_SDK_DISABLED=true

# --- WORKER MODE ---
# "auto" = MCP starts/stops worker on demand (default, saves RAM)
# "persistent" = worker stays up 24/7 for instant call pickup
#   In persistent mode, start manually: python agent.py dev
#   If you forget, MCP will start it for you (but it won't auto-stop)
CLAUVER_WORKER_MODE=auto

# --- NOTE ---
# Edge TTS (default free TTS) requires ffmpeg: brew install ffmpeg
